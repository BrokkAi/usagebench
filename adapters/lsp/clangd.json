{
  "id": "clangd",
  "name": "clangd",
  "languages": ["cpp"],
  "requestedVersion": "22.1.6",
  "source": "https://github.com/clangd/clangd/releases/tag/22.1.6",
  "command": ["clangd", "--background-index", "--clang-tidy=false"],
  "fileExtensions": [".c", ".cc", ".cpp", ".cxx", ".h", ".hh", ".hpp", ".hxx"],
