    ".h": "cpp",
    ".hh": "cpp",
    ".hpp": "cpp",
    ".hxx": "cpp"
  },
  "workspaceFiles": {"compile_flags.txt": "-std=c++20\n-I.\n-Iinclude\n"},
  "settleMilliseconds": 1500,
  "generateCompileCommands": true
}
